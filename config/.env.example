NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

LOG_LEVEL=INFO

# API authentication (optional: leave empty to disable)
KG_AUTH_MODE=none
KG_API_KEY=
KG_ADMIN_KEY=
KG_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Embedding model paths
EMBEDDING_MODEL_PATH=E:/huggingface_cache/BAAI/bge-m3
HF_HOME=E:/huggingface_cache

# External tool paths (Windows examples, adjust for your OS)
ODA_CONVERTER_PATH=E:/ODA/ODAFileConverter.exe

# CrewAI Agent LLM
# 真实 Key 请写入 config/.env，不要提交到 git
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
KG_AGENT_PROVIDER=deepseek
KG_AGENT_HEAVY_MODEL=deepseek-v4-pro
KG_AGENT_LIGHT_MODEL=deepseek-v4-flash
KG_AGENT_VERBOSE=true
KG_AGENT_DISABLE_THINKING=true
KG_AGENT_TEMPERATURE=0.1
KG_AGENT_MAX_TOKENS=4096
